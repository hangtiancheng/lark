{
  "author": "https://github.com/hangtiancheng",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "mermaid": "^11.14.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.4"
  },
  "lint-staged": {},
  "name": "lark",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangtiancheng/lark.git"
  },
  "scripts": {
    "build": "vitepress build",
    "dev": "vitepress dev",
    "format": "prettier -w ./docs ./.vitepress",
    "prepare": "husky",
    "preview": "vitepress preview",
    "test": "concurrently \"pnpm test:bloom-filter\" \"pnpm test:distributed-lock\" \"pnpm test:math\" \"pnpm test:mini-zustand\" \"pnpm test:react-vue\" \"pnpm test:vue-reactivity\"'",
    "test:bloom-filter": "pnpm --filter @lark/bloom-filter test",
    "test:distributed-lock": "pnpm --filter @lark/distributed-lock test",
    "test:math": "pnpm --filter @lark/math test",
    "test:mini-zustand": "pnpm --filter @lark/mini-zustand test",
    "test:react-vue": "pnpm --filter @lark/react-vue test",
    "test:vue-reactivity": "pnpm --filter @lark/vue-reactivity test"
  },
  "type": "module"
}
