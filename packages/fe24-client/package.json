{
  "name": "@lark/fe24-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:webpack",
    "build": "pnpm build:webpack",
    "dev:webpack": "cross-env NODE_OPTIONS=\"--loader ts-node/esm --no-warnings\" webpack serve --mode development --open --config webpack.config.ts",
    "build:webpack": "cross-env NODE_OPTIONS=\"--loader ts-node/esm --no-warnings\" webpack --mode production --config webpack.config.ts",
    "build:esbuild": "cross-env NODE_ENV=production node ./esbuild.config.js",
    "dev:rsbuild": "rsbuild dev",
    "build:rsbuild": "rsbuild build",
    "build:rollup": "cross-env NODE_ENV=production rollup -c rollup.config.js",
    "build:all": "cross-env SELECTED_ROUTES=* NODE_OPTIONS=\"--loader ts-node/esm --no-warnings\" webpack --mode production --config webpack.config.ts",
    "lint": "eslint . --fix",
    "format": "prettier -w src/ plugins/"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@ant-design/icons": "^6.1.1",
    "@icon-park/react": "^1.4.2",
    "@lark/conditional-bundle-plugin": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/react": "^18.3.28",
    "animate.css": "^4.1.1",
    "antd": "^6.3.4",
    "axios": "^1.14.0",
    "dotenv": "^17.2.3",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "express": "^4.22.1",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.4.0",
    "@inquirer/prompts": "^8.3.2",
    "@apivm/esbuild-style-plugin": "^1.1.7",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-typescript": "^12.1.4",
    "@rollup/plugin-url": "^8.0.2",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.0",
    "@rsbuild/plugin-sass": "^1.5.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@types/webpack-env": "^1.18.8",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv-webpack": "^9.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss-loader": "^8.2.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "rollup": "^4.52.4",
    "rollup-plugin-postcss": "^4.0.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
