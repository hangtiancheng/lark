{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["./src/**/*.ts"]
}
