{
  "name": "@lark/mcp",
  "version": "1.0.0",
  "description": "MCP server for prompts using fastify and mongodb",
  "main": "dist/index.js",
  "scripts": {
    "start": "pnpm build && node dist/index.js",
    "benchmark": "tsx scripts/benchmark.ts",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "cd src/client && rollup -c -w",
    "dev:server": "tsx src/index.ts",
    "build": "concurrently \"pnpm build:server\" \"pnpm build:client\"",
    "build:server": "tsc",
    "build:client": "cd src/client && rollup -c",
    "format": "prettier -w ./"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@koa/bodyparser": "^6.1.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "@langchain/core": "^1.1.35",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.6.1",
    "i18next": "^25.10.3",
    "koa": "^3.1.2",
    "koa-static": "^5.0.0",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/autocannon": "^7.12.7",
    "@types/koa": "^3.0.2",
    "@types/koa-static": "^4.0.4",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autocannon": "^7.15.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup": "^4.60.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "type": "module"
}
