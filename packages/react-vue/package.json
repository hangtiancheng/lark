{
  "name": "@lark/react-vue",
  "description": "Using Vue Composition API in React components.",
  "author": "lark hang<https://github.com/hangtiancheng>",
  "license": "MIT",
  "version": "0.0.1",
  "browser": "dist/index.module.js",
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "production": "./dist/index.module.js",
        "development": "./dist/index.module.dev.js"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangtiancheng/lark.git"
  },
  "keywords": [
    "vue",
    "react",
    "vue-composition-api",
    "vue-in-react",
    "reactivity"
  ],
  "bugs": {
    "url": "https://github.com/hangtiancheng/lark/issues"
  },
  "homepage": "https://github.com/hangtiancheng/lark#readme",
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "test": "vitest run",
    "format": "prettier -w ./",
    "lint": "eslint --fix ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cac": "^7.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@vue/reactivity": "^3.5.32",
    "@vue/runtime-core": "^3.5.32",
    "@vue/shared": "^3.5.32"
  },
  "type": "module"
}
